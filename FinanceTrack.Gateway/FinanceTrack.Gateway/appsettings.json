{
  "ReverseProxy": {
    "Routes": {
      "spa": {
        "ClusterId": "spa-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      },
      "finance-api": {
        "ClusterId": "finance-api-cluster",
        "Match": {
          "Path": "/api/finance/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/finance"
          }
        ]
      }
    },
    "Clusters": {
      "spa-cluster": {
        "Destinations": {
          "spa": {
            "Address": "http://client.browser:5173"
          }
        }
      },
      "finance-api-cluster": {
        "Destinations": {
          "finance-service": {
            "Address": "http://financetrack.finance.web:8080"
          }
        }
      }
    }
  }
}
